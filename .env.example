# ==========================================
# R-LOCALHOST CONFIGURATION
# ==========================================

# Core Server Settings
PORT=4000
MASTER_DOMAIN=YOUR_DOMAIN_NAME

# ==========================================
# PATH CONFIGURATIONS
# Define the absolute path to your modules based on your OS.
# 
# Termux Example: /data/data/com.termux/files/home/rcloud/server
# Windows Example: C:/Users/Username/Projects/rcloud/server
# Linux Example:   /home/username/rcloud/server
# ==========================================

RCLOUD_DIR=/path/to/your/rcloud
RCLOUD_PORT=3000

MC_DIR=/path/to/your/bedrock-server
